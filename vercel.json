{
  "version": 2,
  "outputDirectory": "frontend",
  "builds": [
    {
      "src": "frontend/**/*",
      "use": "@vercel/static"
    }
  ],
  "routes": [
    { "src": "/demo", "dest": "/frontend/demo.html" },
    { "src": "/leaderboard", "dest": "/frontend/leaderboard.html" },
    { "src": "/dashboard", "dest": "/frontend/dashboard.html" },
    { "src": "/register", "dest": "/frontend/register.html" },
    { "src": "/(.*)", "dest": "/frontend/$1" }
  ]
}
