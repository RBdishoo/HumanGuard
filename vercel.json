{
  "version": 2,
  "outputDirectory": "frontend",
  "routes": [
    { "src": "/demo", "dest": "/demo.html" },
    { "src": "/leaderboard", "dest": "/leaderboard.html" },
    { "src": "/dashboard", "dest": "/dashboard.html" },
    { "src": "/register", "dest": "/register.html" },
    { "src": "/client", "dest": "/client_dashboard.html" },
    { "src": "/bot-simulator", "dest": "/bot_simulator.html" },
    { "src": "/", "dest": "/demo.html" },
    { "src": "/(.*)\\.html", "dest": "/$1.html" },
    { "src": "/(.*)", "dest": "/$1.html" }
  ]
}
